    "privacy.section.compliance.content" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hissedar operates in full compliance with Capital Markets Board (SPK) regulations. Investor information is stored for the period required by SPK legislation and presented to audit authorities when necessary."
          }
        }
      }
    },
    "privacy.section.compliance.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Regulatory Compliance"
          }
        }
      }
    },
    "privacy.section.data_collection.content" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hissedar collects your name, email, phone number, national ID, and address information to provide our services. Your bank account details and investment history are also stored for financial transactions. All data is processed under GDPR/KVKK compliance."
          }
        }
      }
    },
    "privacy.section.data_collection.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Collected Data"
          }
        }
      }
    },
    "privacy.section.rights.content" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Under KVKK/GDPR, you have the right to access, correct, delete, and transfer your data. You can exercise these rights within the app or by contacting us via email."
          }
        }
      }
    },
    "privacy.section.rights.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your Rights"
          }
        }
      }
    },
    "privacy.section.security.content" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AES-256 encryption, TLS 1.3 protocols, and multi-layered security infrastructure are used. Financial data is protected at bank-level security standards. Regular security audits are conducted."
          }
        }
      }
    },
    "privacy.section.security.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Data Security"
          }
        }
      }
    },
    "privacy.section.tracking.content" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Analytical tools are used to improve the app experience. Cookies are only used for session management and remembering user preferences. Third-party tracking cookies are not used."
          }
        }
      }
    },
    "privacy.section.tracking.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cookies and Tracking"
          }
        }
      }
    },
    "privacy.section.usage.content" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The data we collect is used solely for service delivery, legal obligations, security verification, and service improvements. Your data is never shared with third parties for marketing purposes."
          }
        }
      }
    },
