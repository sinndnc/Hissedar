    "privacy.section.compliance.content" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hissedar operates in full compliance with Capital Markets Board (SPK) regulations. Investor information is stored for the period required by SPK legislation and presented to audit authorities when necessary."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hissedar, Sermaye Piyasası Kurulu (SPK) düzenlemelerine tam uyum içinde faaliyet göstermektedir. Yatırımcı bilgileri, SPK mevzuatının gerektirdiği süre boyunca saklanır ve gerektiğinde denetim mercilerine sunulur."
          }
        }
      }
    },
    "privacy.section.compliance.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Regulatory Compliance"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mevzuat Uyumluluğu"
          }
        }
      }
    },
    "privacy.section.data_collection.content" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hissedar collects your name, email, phone number, national ID, and address information to provide our services. Your bank account details and investment history are also stored for financial transactions. All data is processed under GDPR/KVKK compliance."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hissedar, hizmetlerimizi sunmak için adınızı, e-postanızı, telefon numaranızı, ulusal kimlik numaranızı ve adres bilgilerinizi toplar. Finansal işlemler için banka hesap bilgileriniz ve yatırım geçmişiniz de saklanır. Tüm veriler GDPR/KVKK uyumluluğu çerçevesinde işlenir."
          }
        }
      }
    },
    "privacy.section.data_collection.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Collected Data"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toplanan Veriler"
          }
        }
      }
    },
    "privacy.section.rights.content" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Under KVKK/GDPR, you have the right to access, correct, delete, and transfer your data. You can exercise these rights within the app or by contacting us via email."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "KVKK/GDPR kapsamında, verilerinize erişme, düzeltme, silme ve aktarma hakkına sahipsiniz. Bu haklarınızı uygulama içinden veya e-posta yoluyla bizimle iletişime geçerek kullanabilirsiniz."
          }
        }
      }
    },
    "privacy.section.rights.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your Rights"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Haklarınız"
          }
        }
      }
    },
    "privacy.section.security.content" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AES-256 encryption, TLS 1.3 protocols, and multi-layered security infrastructure are used. Financial data is protected at bank-level security standards. Regular security audits are conducted."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AES-256 şifreleme, TLS 1.3 protokolleri ve çok katmanlı güvenlik altyapısı kullanılmaktadır. Finansal veriler banka düzeyinde güvenlik standartlarında korunmaktadır. Düzenli güvenlik denetimleri yapılmaktadır."
          }
        }
      }
    },
    "privacy.section.security.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Data Security"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Veri Güvenliği"
          }
        }
      }
    },
    "privacy.section.tracking.content" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Analytical tools are used to improve the app experience. Cookies are only used for session management and remembering user preferences. Third-party tracking cookies are not used."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Analytical tools are used to improve the app experience. Cookies are only used for session management and remembering user preferences. Third-party tracking cookies are not used."
          }
        }
      }
    },
