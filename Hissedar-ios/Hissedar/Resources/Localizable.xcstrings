    "support.faq.a1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can purchase tokens in any amount by clicking the 'Buy' button on an asset page. Payment is automatically deducted from your wallet balance."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bir varlık sayfasındaki 'Satın Al' düğmesine tıklayarak istediğiniz miktarda token satın alabilirsiniz. Ödeme otomatik olarak cüzdan bakiyenizden düşülür."
          }
        }
      }
    },
    "support.faq.a2" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rental yields are automatically distributed to token holders on the 1st and 15th of each month. Yield is calculated based on your token share."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kira getirileri, her ayın 1'i ve 15'inde otomatik olarak token sahiplerine dağıtılır. Getiri, token payınıza göre hesaplanır."
          }
        }
      }
    },
    "support.faq.q1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How to buy tokens?"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Token nasıl satın alınır?"
          }
        }
      }
    },
    "support.faq.q1.answer" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can purchase tokens in any amount by clicking the 'Buy' button on an asset page. Payment is automatically deducted from your wallet balance."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bir varlık sayfasındaki 'Satın Al' düğmesine tıklayarak istediğiniz miktarda token satın alabilirsiniz. Ödeme otomatik olarak cüzdan bakiyenizden düşülür."
          }
        }
      }
    },
