          }
        }
      }
    },
    "privacy.section.usage.content" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The data we collect is used solely for service delivery, legal obligations, security verification, and service improvements. Your data is never shared with third parties for marketing purposes."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Topladığımız veriler yalnızca hizmet sunumu, yasal yükümlülükler, güvenlik doğrulaması ve hizmet iyileştirmeleri için kullanılır. Verileriniz hiçbir zaman pazarlama amaçlı olarak üçüncü taraflarla paylaşılmaz."
          }
        }
      }
    },
    "privacy.section.usage.title" : {
