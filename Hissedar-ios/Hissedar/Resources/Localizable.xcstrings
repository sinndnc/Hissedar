      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When are rental yields distributed?"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kira gelirleri ne zaman dağıtılır?"
          }
