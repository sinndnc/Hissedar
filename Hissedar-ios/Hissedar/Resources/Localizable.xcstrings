    "support.faq.q3.answer" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Withdrawals via bank transfer are typically completed within 1-3 business days. Please ensure your IBAN information is correct."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Banka havalesi yoluyla para çekme işlemleri genellikle 1-3 iş günü içinde tamamlanır. Lütfen IBAN bilgilerinizin doğru olduğundan emin olun."
          }
        }
      }
    },
    "support.faq.q3.question" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How long does withdrawal take?"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para çekme işlemi ne kadar sürer?"
          }
        }
      }
    },
    "support.faq.q4.answer" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Minimum investment varies by asset but generally starts from ₺100. You can see the minimum purchase amount for each asset on its detail page."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Minimum yatırım tutarı varlığa göre değişmekle birlikte genellikle 100 TL'den başlar. Her varlığın minimum satın alma tutarını ilgili varlığın detay sayfasında görebilirsiniz."
          }
        }
      }
    },
    "support.faq.q4.question" : {
      "extractionState" : "manual",
