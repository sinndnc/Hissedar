    "support.faq.q2.answer" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rental yields are automatically distributed to token holders on the 1st and 15th of each month. Yield is calculated based on your token share."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kira getirileri, her ayın 1'i ve 15'inde otomatik olarak token sahiplerine dağıtılır. Getiri, token payınıza göre hesaplanır."
          }
        }
      }
    },
    "support.faq.q2.question" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When are rental yields distributed?"
          }
